---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import { goals, healthData } from '../../../data/healthData';
import { ArrowLeft, Target, Calendar, CheckCircle2, XCircle } from 'lucide-react';
import { format, parseISO, eachDayOfInterval, isWithinInterval } from 'date-fns';

export function getStaticPaths() {
  return goals.map(goal => ({
    params: { id: goal.id },
    props: { goal },
  }));
}

const { goal } = Astro.props;
const { id } = Astro.params;

// Filter data for this goal
const goalData = healthData.filter(d => 
  isWithinInterval(parseISO(d.date), { 
    start: parseISO(goal.startDate), 
    end: parseISO(goal.endDate) 
  })
);

// Filter other goals
const otherGoals = goals.filter(g => g.id !== goal.id);

// Calculate stats
const daysTracked = goalData.length;
const totalDays = eachDayOfInterval({ 
    start: parseISO(goal.startDate), 
    end: parseISO(goal.endDate) 
}).length;

const completionRate = goalData.reduce((acc, day) => {
    const completed = day.goalActivitiesCompleted?.filter(Boolean).length || 0;
    const total = day.goalActivitiesCompleted?.length || 1;
    return acc + (completed / total);
}, 0) / (daysTracked || 1) * 100;

const avgWeight = goalData.reduce((acc, d) => acc + d.weight, 0) / (daysTracked || 1);
const startWeight = goalData[goalData.length - 1]?.weight; // Oldest
const currentWeight = goalData[0]?.weight; // Newest
const weightChange = currentWeight - startWeight;

---

<Layout title={`${goal.title} | Goal Summary`}>
  <Navbar client:load />
  <div class="min-h-screen bg-background text-foreground pt-40 pb-24 px-6">
    <div class="container mx-auto">
      <a href="/health" class="inline-flex items-center gap-2 text-muted-foreground hover:text-primary mb-8 font-mono text-xs uppercase tracking-widest transition-colors">
        <ArrowLeft className="w-4 h-4" />
        Back to Dashboard
      </a>

      <header class="mb-12 border-b border-border pb-12">
        <div class="flex items-center gap-4 mb-4">
            <span class="px-3 py-1 rounded-full text-xs font-mono bg-primary/10 text-primary border border-primary/20">
                {goal.startDate} — {goal.endDate}
            </span>
            <span class="font-mono text-xs text-muted-foreground">
                {daysTracked} / {totalDays} Days Tracked
            </span>
        </div>
        <h1 class="font-display text-5xl md:text-7xl mb-6">{goal.title}</h1>
        <p class="text-xl text-muted-foreground font-mono leading-relaxed max-w-2xl">
            {goal.description}
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="p-6 rounded-xl bg-muted/10 border border-border">
            <h3 class="font-mono text-xs uppercase tracking-widest text-muted-foreground mb-2">Adherence</h3>
            <div class="flex items-baseline gap-2">
                <span class="font-display text-4xl">{completionRate.toFixed(0)}%</span>
                <span class="text-xs text-muted-foreground">Avg. Daily Completion</span>
            </div>
        </div>
        <div class="p-6 rounded-xl bg-muted/10 border border-border">
            <h3 class="font-mono text-xs uppercase tracking-widest text-muted-foreground mb-2">Weight Change</h3>
            <div class="flex items-baseline gap-2">
                <span class={`font-display text-4xl ${weightChange < 0 ? 'text-green-500' : 'text-foreground'}`}>
                    {weightChange > 0 ? '+' : ''}{weightChange.toFixed(1)}
                </span>
                <span class="text-xs text-muted-foreground">lbs</span>
            </div>
            <div class="mt-2 text-xs font-mono text-muted-foreground">
                {startWeight} → {currentWeight}
            </div>
        </div>
        <div class="p-6 rounded-xl bg-muted/10 border border-border">
             <h3 class="font-mono text-xs uppercase tracking-widest text-muted-foreground mb-2">Avg. Weight</h3>
            <div class="flex items-baseline gap-2">
                <span class="font-display text-4xl">{avgWeight.toFixed(1)}</span>
                <span class="text-xs text-muted-foreground">lbs</span>
            </div>
        </div>
      </div>

      <section class="space-y-8">
        <h2 class="font-display text-3xl mb-8">Daily Journal & Progress</h2>
        
        {goalData.map((day) => (
            <div class="group relative pl-8 border-l border-border pb-8 last:pb-0">
                <div class="absolute -left-[5px] top-0 w-2.5 h-2.5 rounded-full bg-border group-hover:bg-primary transition-colors"></div>
                
                <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-4">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-mono text-sm font-bold">{day.date}</span>
                            <span class="text-xs text-muted-foreground">Day {Math.floor((parseISO(day.date).getTime() - parseISO(goal.startDate).getTime()) / (1000 * 60 * 60 * 24)) + 1}</span>
                        </div>
                        <p class="text-muted-foreground italic">"{day.journalEntry || 'No journal entry for this day.'}"</p>
                    </div>
                    
                    {/* Mini Activity Grid */}
                    <div class="flex gap-1">
                        {day.goalActivitiesCompleted?.map((completed, i) => (
                            <div class="relative group/tooltip">
                                {completed ? (
                                    <CheckCircle2 className="w-4 h-4 text-green-500" />
                                ) : (
                                    <XCircle className="w-4 h-4 text-red-500/30" />
                                )}
                                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-background border border-border text-[10px] whitespace-nowrap rounded opacity-0 group-hover/tooltip:opacity-100 transition-opacity pointer-events-none">
                                    {goal.targetActivities[i]}
                                </span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        ))}
      </section>

      <section class="mt-24 pt-12 border-t border-border">
        <h2 class="font-display text-2xl mb-8">Other Goals</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {otherGoals.map((otherGoal) => (
            <a href={`/health/goal/${otherGoal.id}`} class="block p-6 rounded-xl bg-muted/10 border border-border hover:bg-muted/20 transition-colors group">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full" style={{ backgroundColor: otherGoal.color }}></span>
                <span class="font-mono text-xs text-muted-foreground">{otherGoal.startDate} — {otherGoal.endDate}</span>
              </div>
              <h3 class="font-display text-xl group-hover:text-primary transition-colors">{otherGoal.title}</h3>
              <p class="text-sm text-muted-foreground mt-2 line-clamp-2">{otherGoal.description}</p>
            </a>
          ))}
        </div>
      </section>

    </div>
  </div>
</Layout>
